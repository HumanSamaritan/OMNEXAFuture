# Required for contact form email delivery through Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Destination mailbox for website enquiries
CONTACT_TO_EMAIL=dhiraj.kumar@omnexagoc.com

# Email used for reply-to on user confirmation emails
CONTACT_REPLY_EMAIL=dhiraj.kumar@omnexagoc.com

# Set to true only after CONTACT_FROM_EMAIL uses a Resend-verified domain.
CONTACT_SEND_CONFIRMATION=false

# Use a Resend verified domain email for production.
# Example after verifying omnexagoc.com in Resend:
CONTACT_FROM_EMAIL=OMNeXa Website <noreply@omnexagoc.com>
